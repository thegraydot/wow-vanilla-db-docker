# Copy this file to .env and fill in your values.
# The .env file is gitignored, never commit real credentials.

# MySQL root password (used by init scripts to create databases and users)
MYSQL_ROOT_PASSWORD=change_me_root

# Non-root user created by MySQL Docker image
MYSQL_USER=mangos
MYSQL_PASSWORD=change_me

# Port exposed to the host (used by DBeaver, Python scripts, etc.)
MYSQL_PORT=3306

# Default database for the Python sidecar to connect to.
#
# cmangos: set to "classicmangos" (the world DB created by InstallFullDB.sh).
#   Other DBs created: classiccharacters, classiclogon, classiclogs, classicplayerbots
# vmangos: set to "mangos", also used by the MySQL Docker image to create the initial schema.
#
MYSQL_DATABASE=classicmangos
